# GTKWave Configuration File
# ---------------------------

# Use a clean white background theme
color_back ffffff
color_grid e0e0e0
color_grid2 d0d0d0
color_timegrid 808080
color_value 0000ff
color_vbox 000000
color_vfilter 000000
color_wave 000000
color_wavefill 000000

# Fix the time bar (timeline) background and text colors
color_timeb e8e8e8
color_time 000000

# Make the green waves darker (using a strong forest green #006600)
color_0 006600
color_1 006600

# Make the wave line thicker (default is 1, let's make it 2 or 3)
signal_value_width 2

# Larger fonts for high visibility on slides
fontname_signals Arial 14
fontname_waves Arial 12
